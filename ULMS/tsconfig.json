{
  "compilerOptions": {
    /* ================== Runtime ================== */
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    /* ================== Paths ================== */
    "rootDir": ".",
    "outDir": "dist",

    /* ================== Node ================== */
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* ================== TypeORM (QUAN TRỌNG) ================== */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* ================== Dev Experience ================== */
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,

    /* ================== Compatibility ================== */
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "src/**/*",
    "database/**/*",
    "ormconfig.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}